# Compute factorial of 5

# n = 5
PUSH 5
PUSH 0
MSTORE

# result = 1
PUSH 1
PUSH 1
MSTORE

loop:
# load n
PUSH 0
MLOAD

# if n == 0 → end
DUP
PUSH end
JMPI

# if n == 1 → end
DUP
PUSH 1
SUB
PUSH end
JMPI

# result *= n
PUSH 1
MLOAD        # result
SWAP
MUL
PUSH 1
MSTORE

# n -= 1
PUSH 100
MLOAD
PUSH 1
SUB
PUSH 0
MSTORE

PUSH loop
JMP

end:
# store result in storage[0]
PUSH 1
MLOAD
PUSH 0
SSTORE

STOP